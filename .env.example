# Vorlage für die lokale .env — kopieren nach `.env` und ausfüllen.
# `.env` ist per .gitignore ausgeschlossen und darf NIE eingecheckt werden.
#
#   cp .env.example .env
#
# Hinweis: Im fertigen Programm liegt der Schlüssel in der macOS-Keychain,
# nicht in dieser Datei. Die .env dient nur der Entwicklung.

# ── KI-Anbieter ────────────────────────────────────────────────
# Aktuell: "gemini". Später ggf. "anthropic" oder "openai".
AI_PROVIDER=gemini

# API-Schlüssel des gewählten Anbieters.
# Gemini: https://aistudio.google.com/apikey
AI_API_KEY=

# Modell für Strukturanalyse und Themenextraktion.
# Flash-Lite reicht dafür und ist am günstigsten.
AI_MODEL=gemini-2.5-flash-lite

# ── Kostenkontrolle ────────────────────────────────────────────
# Monatliches Limit in Euro. Bei Überschreitung stoppt die App
# KI-Aufrufe und weist darauf hin. 0 = kein Limit.
AI_MONTHLY_BUDGET_EUR=5

# ── Entwicklung ────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# Wenn gesetzt, werden statt echter API-Aufrufe Beispieldaten
# verwendet — nützlich für Tests ohne Kosten.
AI_MOCK=false
