{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lernplaner",
  "version": "0.22.0",
  "identifier": "com.henrigrimme.lernplaner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lernplaner",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDMUM5QzBGNDVDMjdCQ0MKUldUTWU4SkZENXdjN05qaUZKeDRRbmNPOVl0Vm5oTmtxRlZuWFdLZFlSN2NwaytUYkYwRnpUS3QK",
      "endpoints": [
        "https://github.com/henrigrimme/Lernplaner/releases/latest/download/latest.json"
      ]
    }
  }
}
